# Crewculator — environment variable template
#
# Copy this file to .env.local (which is gitignored) and fill in the real values.
# .env.local is read by `netlify dev` for local development.
# Production values go directly into the Netlify dashboard, not into any file.

# Xola API key. Get this from the Xola admin panel under API access.
# Use the SANDBOX key during Phase 0–1; switch to production in Phase 2.
XOLA_API_KEY=

# Xola seller / account ID. Single value — we operate one Xola account.
XOLA_SELLER_ID=

# Xola API base URL. Sandbox for development, production for Phase 2 onward.
#   Sandbox:    https://sandbox.xola.com/api
#   Production: https://xola.com/api
XOLA_API_BASE=https://sandbox.xola.com/api

# Biweekly pay-period anchor (DEC-004). ISO 8601 date (YYYY-MM-DD) marking
# the start of a known biweekly window. The UI computes "current period"
# by walking forward from this anchor in 14-day steps.
# Set this once during Phase 2 task 2.1 — leave blank for now.
PAY_PERIOD_ANCHOR=
